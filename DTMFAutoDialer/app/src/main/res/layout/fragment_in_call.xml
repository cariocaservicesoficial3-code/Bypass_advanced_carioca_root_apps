<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Card: Status da Chamada -->
        <LinearLayout
            android:id="@+id/card_call_active"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● CHAMADA EM ANDAMENTO"
                android:textColor="@color/success"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_incall_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aguardando ligação..."
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_call_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhuma chamada ativa"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card: Sequência DTMF -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sequência para Digitar"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cole ou edite a sequência. Ao tocar em DIGITAR, os tons DTMF serão enviados diretamente pela API do Android."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/edit_dtmf_incall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_background"
                android:hint="Cole CPF, ramal, senha, *123#..."
                android:inputType="text"
                android:maxLines="3"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="20sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_paste_incall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/button_secondary"
                    android:text="COLAR"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_clear_incall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_danger"
                    android:text="LIMPAR"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card: Delay (sincronizado com aba Discador) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delay entre dígitos:"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_delay_incall_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500ms"
                    android:textColor="@color/purple_light"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_delay_incall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="1400"
                android:progress="400" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100ms (rápido) ←→ 1500ms (lento)"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Status e Progresso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_typing_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pronto para digitar"
                android:textColor="@color/purple_light"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/progress_dtmf"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:progressTint="@color/purple_primary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Botão DIGITAR AGORA -->
        <Button
            android:id="@+id/btn_start_dtmf"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/button_primary"
            android:text="⌨  DIGITAR AGORA"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Botão PARAR DIGITAÇÃO -->
        <Button
            android:id="@+id/btn_stop_dtmf"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/button_danger"
            android:text="■  PARAR DIGITAÇÃO"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- Botão DESLIGAR -->
        <Button
            android:id="@+id/btn_hangup"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/button_danger"
            android:text="📵  DESLIGAR"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
