<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0D1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#"
                android:textColor="#A78BFA"
                android:textSize="48sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DTMF Auto Dialer"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Módulo LSPosed - Carioca Services"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Status do Módulo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status do Módulo"
                android:textColor="#D1D5DB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_module_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verificando..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Campo de Dígitos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sequência de Números"
                android:textColor="#D1D5DB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cole CPF, telefone ou qualquer sequência numérica"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <EditText
                android:id="@+id/edit_digits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_background"
                android:hint="Ex: 072.818.591-12"
                android:inputType="text"
                android:maxLines="3"
                android:padding="14dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btn_paste"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/button_secondary"
                android:text="COLAR DA ÁREA DE TRANSFERÊNCIA"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Configurações -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configurações"
                android:textColor="#D1D5DB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Delay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delay entre dígitos:"
                    android:textColor="#D1D5DB"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_delay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="300ms"
                    android:textColor="#A78BFA"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="900"
                android:progress="200" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100ms (rápido) ←→ 1000ms (lento)"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:gravity="center" />

            <!-- Auto-start -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Iniciar widget automaticamente"
                    android:textColor="#D1D5DB"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/switch_auto_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botão Iniciar Widget -->
        <Button
            android:id="@+id/btn_start_widget"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/button_primary"
            android:text="INICIAR WIDGET FLUTUANTE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Instruções -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Como Usar"
                android:textColor="#D1D5DB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Ative o módulo no LSPosed para o app Telefone\n2. Copie a sequência de números (CPF, telefone, etc.)\n3. Inicie o widget flutuante\n4. Faça a ligação normalmente\n5. No widget, cole os números e toque em DIGITAR\n6. O módulo digitará cada número automaticamente\n\nFormatos aceitos:\n• 072.818.591-12 (com pontuação)\n• 07281859112 (somente números)\n• *123# (códigos USSD)\n• Qualquer combinação de 0-9, * e #"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Histórico -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Histórico"
                    android:textColor="#D1D5DB"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_clear_history"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/button_danger"
                    android:text="Limpar"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhum histórico"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carioca Services - DTMF Auto Dialer v1.0\nMódulo LSPosed para digitação automática DTMF"
            android:textColor="#4B5563"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
